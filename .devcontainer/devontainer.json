{
    "name": "ESP-IDF Development Container",
    "dockerFile": "../Dockerfile",
    "context": "..",
    "workspaceFolder": "/esp",
    "settings": {
        "terminal.integrated.shell.linux": "/bin/bash"
    },
    "extensions": [
        "espressif.esp-idf-extension",
        "ms-vscode.cpptools",
        "ms-python.python"
    ],
    "runArgs": [
        "--device=/dev/ttyUSB0"
    ],
    "postCreateCommand": "source $IDF_PATH/export.sh"
}